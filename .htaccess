# .htaccess - Versão corrigida
Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Regra especial para debug
    RewriteRule ^debug\.php$ - [L]
    
    # Permitir acesso direto a arquivos existentes
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]
    
    # Permitir acesso a diretórios existentes
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ - [L]
    
    # === ROTAS DO SISTEMA ===
    
    # Autenticação
    RewriteRule ^login/?$ views/auth/login.php [L]
    RewriteRule ^registro/?$ views/auth/register.php [L]
    RewriteRule ^recuperar-senha/?$ views/auth/recover-password.php [L]
    RewriteRule ^logout/?$ controllers/AuthController.php?action=logout [L]
    
    # Cliente
    RewriteRule ^cliente/dashboard/?$ views/client/dashboard.php [L]
    RewriteRule ^cliente/extrato/?$ views/client/statement.php [L]
    RewriteRule ^cliente/lojas-parceiras/?$ views/client/partner-stores.php [L]
    RewriteRule ^cliente/perfil/?$ views/client/profile.php [L]
    
    # Admin
    RewriteRule ^admin/?$ views/admin/dashboard.php [L]
    RewriteRule ^admin/dashboard/?$ views/admin/dashboard.php [L]
    RewriteRule ^admin/usuarios/?$ views/admin/users.php [L]
    RewriteRule ^admin/lojas/?$ views/admin/stores.php [L]
    RewriteRule ^admin/transacoes/?$ views/admin/transactions.php [L]
    RewriteRule ^admin/configuracoes/?$ views/admin/settings.php [L]
    RewriteRule ^admin/api/user-management/?$ controllers/UserManagementController.php [L,QSA]
    
    # Lojas
    RewriteRule ^store/dashboard/?$ views/stores/dashboard.php [L]
    RewriteRule ^store/registrar-transacao/?$ views/stores/register-transaction.php [L]
    RewriteRule ^store/transacoes/?$ views/stores/transactions.php [L]
    RewriteRule ^store/perfil/?$ views/stores/profile.php [L]
    
    # API
    RewriteRule ^api/users/?$ api/users.php [L,QSA]
    RewriteRule ^api/transactions/?$ api/transactions.php [L,QSA]
    RewriteRule ^api/openpix/?$ api/openpix.php [L,QSA]
    
    # Index como fallback
    RewriteRule ^$ index.php [L]
</IfModule>

# Configurações PHP
<IfModule mod_php7.c>
    php_flag display_errors off
    php_value error_log logs/error.log
    php_value memory_limit 256M
    php_value max_execution_time 60
</IfModule>

# Segurança
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Cache
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>